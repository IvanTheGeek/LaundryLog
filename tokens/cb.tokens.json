{
  "$schema": "https://design-tokens.org/schemas/2025.10/format.schema.json",
  "color": {
    "$type": "color",
    "neutral": {
      "N50":  { "$value": { "colorSpace": "oklch", "components": [0.975, 0.006, 75] } },
      "N100": { "$value": { "colorSpace": "oklch", "components": [0.940, 0.008, 75] } },
      "N200": { "$value": { "colorSpace": "oklch", "components": [0.880, 0.010, 75] } },
      "N300": { "$value": { "colorSpace": "oklch", "components": [0.800, 0.011, 75] } },
      "N400": { "$value": { "colorSpace": "oklch", "components": [0.680, 0.012, 75] } },
      "N500": { "$value": { "colorSpace": "oklch", "components": [0.560, 0.012, 75] } },
      "N600": { "$value": { "colorSpace": "oklch", "components": [0.450, 0.011, 75] } },
      "N700": { "$value": { "colorSpace": "oklch", "components": [0.350, 0.010, 75] } },
      "N800": { "$value": { "colorSpace": "oklch", "components": [0.260, 0.009, 75] } },
      "N900": { "$value": { "colorSpace": "oklch", "components": [0.180, 0.008, 75] } },
      "N950": { "$value": { "colorSpace": "oklch", "components": [0.110, 0.007, 75] } }
    },
    "amber": {
      "N50":  { "$value": { "colorSpace": "oklch", "components": [0.970, 0.030, 85] } },
      "N100": { "$value": { "colorSpace": "oklch", "components": [0.930, 0.060, 85] } },
      "N200": { "$value": { "colorSpace": "oklch", "components": [0.880, 0.100, 80] } },
      "N300": { "$value": { "colorSpace": "oklch", "components": [0.820, 0.140, 78] } },
      "N400": { "$value": { "colorSpace": "oklch", "components": [0.760, 0.170, 75] } },
      "N500": { "$value": { "colorSpace": "oklch", "components": [0.700, 0.185, 70] } },
      "N600": { "$value": { "colorSpace": "oklch", "components": [0.620, 0.175, 65] } },
      "N700": { "$value": { "colorSpace": "oklch", "components": [0.520, 0.160, 60] } },
      "N800": { "$value": { "colorSpace": "oklch", "components": [0.420, 0.130, 58] } },
      "N900": { "$value": { "colorSpace": "oklch", "components": [0.320, 0.100, 55] } }
    },
    "green": {
      "N100": { "$value": { "colorSpace": "oklch", "components": [0.930, 0.060, 145] } },
      "N500": { "$value": { "colorSpace": "oklch", "components": [0.580, 0.155, 145] } },
      "N700": { "$value": { "colorSpace": "oklch", "components": [0.420, 0.130, 145] } }
    },
    "red": {
      "N100": { "$value": { "colorSpace": "oklch", "components": [0.930, 0.055, 25] } },
      "N500": { "$value": { "colorSpace": "oklch", "components": [0.550, 0.185, 25] } },
      "N700": { "$value": { "colorSpace": "oklch", "components": [0.400, 0.155, 25] } }
    },
    "blue": {
      "N100": { "$value": { "colorSpace": "oklch", "components": [0.930, 0.040, 240] } },
      "N500": { "$value": { "colorSpace": "oklch", "components": [0.560, 0.155, 240] } },
      "N700": { "$value": { "colorSpace": "oklch", "components": [0.400, 0.130, 240] } }
    },
    "white": { "$value": { "colorSpace": "oklch", "components": [1.000, 0, 0] } },
    "black": { "$value": { "colorSpace": "oklch", "components": [0.000, 0, 0] } },
    "text": {
      "primary":   { "$value": "{color.neutral.N900}" },
      "secondary": { "$value": "{color.neutral.N600}" },
      "muted":     { "$value": "{color.neutral.N400}" },
      "inverse":   { "$value": "{color.neutral.N50}" },
      "accent":    { "$value": "{color.amber.N700}" },
      "success":   { "$value": "{color.green.N700}" },
      "danger":    { "$value": "{color.red.N700}" }
    },
    "surface": {
      "base":    { "$value": "{color.neutral.N50}" },
      "raised":  { "$value": { "colorSpace": "oklch", "components": [1.000, 0, 0] } },
      "sunken":  { "$value": "{color.neutral.N100}" },
      "overlay": { "$value": { "colorSpace": "srgb",  "components": [0, 0, 0], "alpha": 0.48 } }
    },
    "border": {
      "default": { "$value": "{color.neutral.N200}" },
      "strong":  { "$value": "{color.neutral.N300}" },
      "accent":  { "$value": "{color.amber.N300}" }
    },
    "accent": {
      "default": { "$value": "{color.amber.N500}" },
      "hover":   { "$value": "{color.amber.N600}" },
      "subtle":  { "$value": "{color.amber.N50}" },
      "on":      { "$value": { "colorSpace": "oklch", "components": [1.000, 0, 0] } }
    },
    "feedback": {
      "success": {
        "default": { "$value": "{color.green.N500}" },
        "subtle":  { "$value": "{color.green.N100}" }
      },
      "danger": {
        "default": { "$value": "{color.red.N500}" },
        "subtle":  { "$value": "{color.red.N100}" }
      },
      "info": {
        "default": { "$value": "{color.blue.N500}" },
        "subtle":  { "$value": "{color.blue.N100}" }
      }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["DM Sans", "Helvetica Neue", "Arial", "sans-serif"] },
      "body":    { "$value": ["DM Sans", "Helvetica Neue", "Arial", "sans-serif"] },
      "mono":    { "$value": ["JetBrains Mono", "Courier New", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "light":    { "$value": 300 },
      "regular":  { "$value": 450 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs":   { "$value": { "value": 0.6875, "unit": "rem" } },
      "sm":   { "$value": { "value": 0.8125, "unit": "rem" } },
      "base": { "$value": { "value": 0.9375, "unit": "rem" } },
      "md":   { "$value": { "value": 1.0625, "unit": "rem" } },
      "lg":   { "$value": { "value": 1.2500, "unit": "rem" } },
      "xl":   { "$value": { "value": 1.5625, "unit": "rem" } },
      "2xl":  { "$value": { "value": 1.9375, "unit": "rem" } },
      "3xl":  { "$value": { "value": 2.4375, "unit": "rem" } },
      "4xl":  { "$value": { "value": 3.0625, "unit": "rem" } },
      "5xl":  { "$value": { "value": 3.8125, "unit": "rem" } }
    },
    "line-height": {
      "$type": "number",
      "tight":   { "$value": 1.1 },
      "snug":    { "$value": 1.3 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.7 }
    },
    "letter-spacing": {
      "$type": "number",
      "tight":  { "$value": -0.02 },
      "normal": { "$value": 0 },
      "wide":   { "$value": 0.05 },
      "wider":  { "$value": 0.10 }
    }
  },
  "spacing": {
    "$type": "dimension",
    "N0":  { "$value": { "value": 0,  "unit": "px" } },
    "N1":  { "$value": { "value": 4,  "unit": "px" } },
    "N2":  { "$value": { "value": 8,  "unit": "px" } },
    "N3":  { "$value": { "value": 12, "unit": "px" } },
    "N4":  { "$value": { "value": 16, "unit": "px" } },
    "N5":  { "$value": { "value": 20, "unit": "px" } },
    "N6":  { "$value": { "value": 24, "unit": "px" } },
    "N8":  { "$value": { "value": 32, "unit": "px" } },
    "N10": { "$value": { "value": 40, "unit": "px" } },
    "N12": { "$value": { "value": 48, "unit": "px" } },
    "N16": { "$value": { "value": 64, "unit": "px" } },
    "N20": { "$value": { "value": 80, "unit": "px" } },
    "N24": { "$value": { "value": 96, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "xs":   { "$value": { "value": 4,   "unit": "px" } },
    "sm":   { "$value": { "value": 8,   "unit": "px" } },
    "md":   { "$value": { "value": 12,  "unit": "px" } },
    "lg":   { "$value": { "value": 16,  "unit": "px" } },
    "xl":   { "$value": { "value": 20,  "unit": "px" } },
    "2xl":  { "$value": { "value": 24,  "unit": "px" } },
    "pill": { "$value": { "value": 999, "unit": "px" } }
  },
  "shadow": {
    "$type": "shadow",
    "xs": {
      "$value": {
        "color":   { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.06 },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 1, "unit": "px" },
        "blur":    { "value": 2, "unit": "px" },
        "spread":  { "value": 0, "unit": "px" }
      }
    },
    "sm": {
      "$value": [
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.08 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 4, "unit": "px" }, "spread": { "value": 0, "unit": "px" } },
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.05 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 2, "unit": "px" }, "spread": { "value": 0, "unit": "px" } }
      ]
    },
    "md": {
      "$value": [
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.08 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 4,  "unit": "px" }, "blur": { "value": 12, "unit": "px" }, "spread": { "value": 0, "unit": "px" } },
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.05 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1,  "unit": "px" }, "blur": { "value": 3,  "unit": "px" }, "spread": { "value": 0, "unit": "px" } }
      ]
    },
    "lg": {
      "$value": [
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.10 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 8,  "unit": "px" }, "blur": { "value": 24, "unit": "px" }, "spread": { "value": 0, "unit": "px" } },
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.06 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 2,  "unit": "px" }, "blur": { "value": 6,  "unit": "px" }, "spread": { "value": 0, "unit": "px" } }
      ]
    },
    "xl": {
      "$value": [
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.12 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 16, "unit": "px" }, "blur": { "value": 40, "unit": "px" }, "spread": { "value": 0, "unit": "px" } },
        { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.07 }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 4,  "unit": "px" }, "blur": { "value": 12, "unit": "px" }, "spread": { "value": 0, "unit": "px" } }
      ]
    },
    "focus-ring": {
      "$value": {
        "color":   "{color.amber.N300}",
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 0, "unit": "px" },
        "blur":    { "value": 0, "unit": "px" },
        "spread":  { "value": 3, "unit": "px" }
      }
    }
  },
  "duration": {
    "$type": "duration",
    "instant": { "$value": { "value": 0,   "unit": "ms" } },
    "fast":    { "$value": { "value": 100, "unit": "ms" } },
    "normal":  { "$value": { "value": 200, "unit": "ms" } },
    "slow":    { "$value": { "value": 350, "unit": "ms" } }
  },
  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.40, 0.00, 0.20, 1.0] },
    "spring":   { "$value": [0.34, 1.40, 0.64, 1.0] },
    "out":      { "$value": [0.00, 0.00, 0.20, 1.0] }
  }
}
